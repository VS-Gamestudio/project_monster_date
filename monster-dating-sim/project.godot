; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Monster Dating Sim"
run/main_scene="uid://dkj1xh1lhqswt"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/images/icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[file_customization]

folder_colors={
"res://add-ons/": "gray",
"res://assets/": "pink",
"res://assets/audio/": "purple",
"res://scenes/": "orange",
"res://scripts/": "blue"
}

[internationalization]

locale/language_filter=["de", "en"]
locale/country_filter=["DE", "GB"]
locale/locale_filter_mode=1

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
